{
  "name": "kukla2d",
  "private": true,
  "version": "0.9.0-beta",
  "license": "MIT",
  "type": "module",
  "packageManager": "npm@11.17.0",
  "workspaces": [
    "packages/*",
    "packages/adapters/*"
  ],
  "engines": {
    "node": ">=24.18.0 <25",
    "npm": ">=11.17.0 <12"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:e2e": "npm run build && node scripts/prepare-e2e-dist.mjs",
    "lint": "eslint . --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check:ts-graph": "node scripts/check-typescript-graph.mjs",
    "check:typescript-migration": "node scripts/check-typescript-migration.mjs",
    "check:canvas-boundaries": "node scripts/check-canvas-boundaries.mjs",
    "check:deadcode": "knip --cache --treat-config-hints-as-errors",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check:full": "node scripts/run-check.mjs",
    "check": "npm run check:full",
    "test:e2e": "npm run build:e2e && playwright test"
  },
  "dependencies": {
    "@kukla2d/adapter-phaser-atlas": "*",
    "@kukla2d/contracts": "*",
    "@fontsource/inter": "^5.2.6",
    "@fontsource/lato": "^5.2.6",
    "@fontsource/montserrat": "^5.2.6",
    "@fontsource/open-sans": "^5.2.6",
    "@fontsource/poppins": "^5.2.6",
    "@fontsource/roboto": "^5.2.6",
    "@fontsource/source-sans-3": "^5.2.8",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-context-menu": "^2.2.1",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@xstate/react": "^6.1.0",
    "ag-psd": "^30.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "delaunator": "^5.1.0",
    "gifenc": "^1.0.3",
    "gl-matrix": "^3.4.4",
    "immer": "^11.1.4",
    "jszip": "^3.10.1",
    "lucide-react": "^0.427.0",
    "pixi-viewport": "^6.0.3",
    "pixi.js": "^8.19.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^2.1.3",
    "tailwind-merge": "^2.4.0",
    "xstate": "^5.32.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "jsdom": "^29.1.1",
    "knip": "^6.20.0",
    "phaser": "4.2.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
