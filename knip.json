{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.mjs", "scripts/scripts_legacy/*.mjs", "test/types/**/*.ts"]
    },
    "packages/application": {
      "ignoreDependencies": [
        "immer",
        "zod",
        "zustand"
      ]
    },
    "packages/document": {
      "ignoreDependencies": [
        "zod"
      ]
    },
    "packages/engine": {
      "ignoreDependencies": [
        "gl-matrix"
      ]
    },
    "packages/math2d": {
      "ignoreDependencies": [
        "gl-matrix"
      ]
    },
    "packages/platform-browser": {
      "ignoreDependencies": [
        "jszip",
        "zod"
      ]
    },
    "packages/adapters/live2d": {
      "ignoreDependencies": [
        "jszip"
      ]
    },
    "packages/adapters/psd": {
      "ignoreDependencies": [
        "ag-psd"
      ]
    },
    "packages/adapters/spine": {
      "ignoreDependencies": [
        "jszip"
      ]
    },
  },
  "ignore": [
    "src/components/ui/**",
    "src/features/physics/**",
    "src/io/live2d/**",
    "test/fixtures/**"
  ],
  "ignoreIssues": {
    "src/features/canvas/application/workspaceLoadTransaction.ts": ["types"],
    "src/features/projects/application/useProjectSession.ts": ["types"],
    "src/features/auto-motion/application/useAddMotionWizard.ts": ["types"],
    "src/features/auto-motion/index.ts": ["types"],
    "src/features/preferences/index.ts": ["types"]
  },
  "exclude": [
    "exports"
  ]
}
